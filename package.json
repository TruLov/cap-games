{
  "name": "cap-games",
  "version": "1.0.0",
  "description": "Multiplayer browser game platform on SAP BTP",
  "scripts": {
    "start": "cds-serve",
    "dev":   "cds watch --include games"
  },
  "workspaces": [
    "games/*"
  ],
  "dependencies": {
    "@sap/cds":                      "^10",
    "@cap-js-community/websocket":   "^1",
    "@cap-games/tictactoe":          "*",
    "express":                       "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite":  "*",
    "@sap/cds-dk":     "^10"
  },
  "cds": {
    "requires": {
      "auth": {
        "[development]": { "kind": "mocked" },
        "[production]":  { "kind": "ias" }
      },
      "db": {
        "[development]": { "kind": "sqlite", "credentials": { "url": ":memory:" } },
        "[production]":  { "kind": "hana" }
      }
    },
    "websocket": { "kind": "ws" },
    "features": {
      "compat_srv_getters":    false,
      "compat_texts_entities": false
    }
  }
}
