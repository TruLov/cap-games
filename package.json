{
  "name": "cap-games",
  "version": "1.0.0",
  "description": "Multiplayer browser game platform on SAP BTP",
  "type": "module",
  "scripts": {
    "start": "cds-serve",
    "dev": "cds watch --include games",
    "lint": "eslint srv/ games/*/index.js games/*/cds-plugin.js",
    "test": "npm run test:unit && npm run test:int",
    "test:unit": "cds test -x integration",
    "test:int": "CDS_TEST_ENV_CHECK=y cds test integration"
  },
  "workspaces": [
    "games/*"
  ],
  "dependencies": {
    "@cap-games/kaiten": "*",
    "@cap-games/tictactoe": "*",
    "@cap-js-community/websocket": "^1",
    "@sap/cds": "^10",
    "express": "^4"
  },
  "devDependencies": {
    "@cap-js/cds-test": "^1.0.1",
    "@cap-js/sqlite": "*",
    "@sap/cds-dk": "^10",
    "eslint": "^10.7.0"
  },
  "cds": {
    "requires": {
      "auth": {
        "[development]": {
          "kind": "mocked"
        },
        "[production]": {
          "kind": "ias"
        }
      },
      "db": {
        "[development]": {
          "kind": "sqlite",
          "credentials": {
            "url": ":memory:"
          }
        },
        "[production]": {
          "kind": "hana"
        }
      }
    },
    "websocket": {
      "kind": "ws"
    }
  }
}
