{
  "authenticationMethod": "route",
  "websockets": { "enabled": true },
  "routes": [
    {
      "source": "^/ws/(.*)$",
      "target": "/ws/$1",
      "destination": "srv-api",
      "authenticationType": "ias",
      "csrfProtection": false
    },
    {
      "source": "^/odata/(.*)$",
      "target": "/odata/$1",
      "destination": "srv-api",
      "authenticationType": "ias",
      "csrfProtection": true
    },
    {
      "source": "^/(.*)$",
      "target": "$1",
      "destination": "srv-api",
      "authenticationType": "ias",
      "csrfProtection": true
    }
  ]
}
